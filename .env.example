# Copy these into Vercel: Project → Settings → Environment Variables
# (Production + Preview if you deploy PRs)

# Required — used by app/layout generateMetadata() and pages (build + runtime)
CONTRIB_API1=

# Required for blog routes / API that call getBlogs()
GET_BLOGS=

# Optional — local dev when host is localhost (Vercel sets VERCEL_URL automatically)
NEXT_PUBLIC_VERCEL_URL=

# Used in next.config.js
API_URL=
API_KEY=

# --- Cloudflare Pages (full-stack Next.js, not static HTML) ---
# Default "npm run build" is NOT enough: Pages must run the adapter.
#
# Dashboard → Workers & Pages → your project → Settings → Builds:
#   Framework preset:        None (or Next.js — then override commands below)
#   Build command:           npm run pages:build
#   Build output directory:  .vercel/output/static
#   Root directory:          / (repo root)
#   Environment variables:   add the same keys as above (CONTRIB_API1, GET_BLOGS, …)
#   Node version:            20.x recommended
#
# If npm complains about peer dependency "next >=14.3.0", add this build variable in Cloudflare:
#   NPM_CONFIG_LEGACY_PEER_DEPS = true
#
# Optional compatibility flag in project settings: nodejs_compat (often set automatically).
#
# Note: @cloudflare/next-on-pages is deprecated; long-term, migrate to OpenNext + Next 15+.
#   https://opennext.js.org/cloudflare
