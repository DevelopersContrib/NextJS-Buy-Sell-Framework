# Copy these into Vercel: Project → Settings → Environment Variables
# (Production + Preview if you deploy PRs)

# Required — used by app/layout generateMetadata() and pages (build + runtime)
CONTRIB_API1=

# Required for blog routes / API that call getBlogs()
GET_BLOGS=

# Optional — local dev when host is localhost (Vercel sets VERCEL_URL automatically)
NEXT_PUBLIC_VERCEL_URL=

# Used in next.config.js
API_URL=
API_KEY=
